# Puerto del servidor
PORT=3000

NODE_ENV=development

# API Key para autenticar las solicitudes de los agentes de Plática
# Debe ser la misma que usan los agentes en el header X-API-Key
API_SECRET_KEY=tu_api_key_secreta_aqui

# API Key de Geoapify para geocodificar direcciones en texto
# Registro gratuito en: https://www.geoapify.com/ (3,000 req/día sin tarjeta)
# Solo se usa cuando el usuario manda texto en lugar de coordenadas nativas
GEOAPIFY_API_KEY=tu_geoapify_key_aqui
